{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ClickHouse": {
    "Host": "localhost",
    "Port": 8123,
    "Database": "qubic"
  },
  "Bob": {
    "Nodes": [ "https://bobnet.qubic.li" ]
  },
  "AddressLabels": {
    "BundleUrl": "https://static.qubic.org/v1/general/data/bundle.min.json"
  },
  "Analytics": {
    "EnableHolderDistribution": true,
    "EnableNetworkStats": true,
    "EnableBurnStats": true,
    "EnableMinerFlow": true,
    "EnableQearn": true,
    "EnableCcf": true,
    "EnableComputorRevenue": true,
    "EnableTickVotes": true,
    "EnableRewardDistributions": true,
    "EnableExecutionFees": true,
    "EnableOracleEvents": true,
    "EnableCustomFlowJobs": true
  }
}
