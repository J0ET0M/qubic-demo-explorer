{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Seq": {
    "ServerUrl": "",
    "ApiKey": ""
  },
  "ClickHouse": {
    "Host": "localhost",
    "Port": 8123,
    "Database": "qubic"
  },
  "Pruner": {
    "IntervalMinutes": 60,
    "DryRun": true,
    "Rules": [
      {
        "Name": "oracle_replies",
        "DestId": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAFXIB",
        "InputType": 6,
        "KeepDays": 10,
        "PruneLogs": true
      },
      {
        "Name": "zero_amount_transfers",
        "InputType": 0,
        "Amount": 0,
        "KeepDays": 10,
        "PruneLogs": true
      },
      {
        "Name": "contract_debug_logs",
        "LogType": 7,
        "KeepDays": 10
      }
    ]
  }
}
